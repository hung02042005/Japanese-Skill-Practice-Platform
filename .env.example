# Copy thành ".env" (cùng cấp với docker-compose.yml) rồi điền giá trị thật.
# File ".env" đã được .gitignore — KHÔNG commit secret thật vào git.

# Mật khẩu SQL Server "sa" — dùng cho cả container db và backend.
# Production: đặt mật khẩu mạnh (>= 12 ký tự, có hoa/thường/số/ký tự đặc biệt).
MSSQL_SA_PASSWORD=ChangeMe_Strong_Password_123!
