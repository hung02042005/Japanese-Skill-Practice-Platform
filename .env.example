# Copy thành ".env" (cùng cấp với docker-compose.yml) rồi điền giá trị thật.
# File ".env" đã được .gitignore — KHÔNG commit secret thật vào git.

# MySQL — Production: đặt mật khẩu mạnh (>= 12 ký tự, có hoa/thường/số/ký tự đặc biệt).
#
# MYSQL_ROOT_PASSWORD chỉ dùng cho container db (khởi tạo + healthcheck).
# Backend KHÔNG dùng root: nó connect bằng MYSQL_USER/MYSQL_PASSWORD — user này
# chỉ có quyền trên đúng database JLPT_LearningDB, hạn chế thiệt hại nếu lộ.
MYSQL_ROOT_PASSWORD=ChangeMe_Strong_Root_Password_123!
MYSQL_USER=jlpt
MYSQL_PASSWORD=ChangeMe_Strong_Password_123!

# Các biến dưới đây được docker-compose.prod.yml đọc qua ${...} để inject vào
# container backend. Nếu để trống, tính năng tương ứng sẽ không hoạt động trên
# production (Google Sign-in, JWT, gửi email xác minh/đặt lại mật khẩu).
JWT_SECRET=
# GOOGLE_CLIENT_ID: dùng CHUNG cho cả backend (xác thực audience của Google
# token) và frontend (build-arg VITE_GOOGLE_CLIENT_ID, xem docker-compose.yml)
# — để trống thì nút "Đăng nhập bằng Google" sẽ không hiện trên production.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP — bắt buộc để email xác minh / đặt lại mật khẩu hoạt động (xem BUG-09)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
