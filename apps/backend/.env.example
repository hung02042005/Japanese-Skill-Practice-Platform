# Database
DATABASE_URL=jdbc:sqlserver://localhost:1433;databaseName=jlpt_dev;encrypt=true;trustServerCertificate=true
DATABASE_USERNAME=sa
DATABASE_PASSWORD=123

# JWT
JWT_SECRET=your-256-bit-secret-key-here
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# AI (OCR / Speech)
AI_OCR_API_KEY=
AI_SPEECH_API_KEY=

# Payment Gateway
PAYMENT_GATEWAY_KEY=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Google Sign-in
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend URL — dùng để build link xác minh email / đặt lại mật khẩu
# Đặt đúng domain khi deploy production, ví dụ: https://jlpt-platform.com
APP_FRONTEND_URL=http://localhost:3000
