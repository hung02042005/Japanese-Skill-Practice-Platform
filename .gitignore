apps/frontend/dist/
apps/frontend/.env
apps/frontend/.env.local
apps/frontend/.env.*.local
apps/frontend/coverage/

# Legacy paths (nếu còn sót)
frontend/node_modules/
frontend/dist/
node_modules/

