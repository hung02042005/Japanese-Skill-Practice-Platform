# =============================================================================
# .gitignore — JLPT E-Learning Platform
# Stack: React 18 + Vite | Spring Boot 3 + Java 21 + Maven | SQL Server | Redis
# =============================================================================

# ===== ENVIRONMENT (CRITICAL — NEVER COMMIT) =====
.env
.env.*
!.env.example
!apps/**/.env.example

# ===== OS & SYSTEM =====
.DS_Store
Thumbs.db
*~
*.swp
*.swo
ehthumbs.db
Desktop.ini

# ===== IDE =====
.idea/
.vscode/
.eclipse/
.project
.classpath
.settings/
nbproject/

# ===== JAVA / MAVEN =====
target/
*.class
*.jar
*.war
*.ear
hs_err_pid*
.flattened-pom.xml
effective-pom.xml
*.iml

# ===== NODE / FRONTEND =====
node_modules/
dist/
build/
.cache/
*.tsbuildinfo

# ===== VITE =====
.vite/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ===== LOGS =====
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.pid
*.seed
*.pid.lock

# ===== TESTING / COVERAGE =====
coverage/
test-results/
*.lcov
/apps/frontend/html/
/apps/backend/surefire-reports/

# ===== APP DATA & UPLOADS (local runtime) =====
apps/backend/data/
apps/backend/uploads/

# ===== DATABASE =====
dump.rdb
*.db
*.sqlite

# ===== DOCKER (local override) =====
docker-compose.override.yml
.docker/
