apps/backend/*.pid
apps/backend/app.pid
apps/backend/.env
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*

# Maven
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ==============================
# NODE / REACT (Frontend)
# ==============================
