{
  "info": {
    "_postman_id": "c1f77d3b-9a99-4d68-af48-6a3f1246c4f0",
    "name": "JLPT E-Learning Auth APIs",
    "description": "Collection chứa danh sách các API liên quan đến xác thực và đăng nhập (Student, Staff & Admin).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Student Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData && jsonData.status === 200 && jsonData.data && jsonData.data.accessToken) {",
              "    pm.environment.set(\"authToken\", jsonData.data.accessToken);",
              "    pm.test(\"Token saved successfully to authToken environment variable\", function () {",
              "        pm.expect(pm.environment.get(\"authToken\")).to.not.be.undefined;",
              "    });",
              "}",
              "if (jsonData && jsonData.data && jsonData.data.refreshToken) {",
              "    pm.environment.set(\"refreshToken\", jsonData.data.refreshToken);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"{{studentEmail}}\",\n    \"password\": \"{{studentPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
