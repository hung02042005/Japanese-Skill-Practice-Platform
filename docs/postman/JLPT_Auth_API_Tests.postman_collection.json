    {
      "name": "7. Reset Password",
      "description": "⚠️ RPW-01 cần set 'resetPasswordToken' thủ công từ email reset password (nhận sau FPW-01).",
      "item": [
        {
          "name": "RPW-01 Reset password hợp lệ → 200  [cần set resetPasswordToken]",
          "request": {
            "method": "POST",
