{
  "info": {
    "name": "JLPT Auth API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Bộ test đầy đủ cho Authentication API\n\nEndpoints:\n  /api/auth/**          — Student + Admin (unified login)\n  /api/staff/auth/**    — Staff login / setup / change-temp-password\n  /api/admin/**         — Admin operations (tạo staff, reset password)\n\nCách dùng:\n  1. Import collection này\n  2. Import JLPT_Local_Environment.postman_environment.json\n  3. Chọn environment 'JLPT Local'\n  4. Chạy tuần tự folder 1 → 12\n\nLưu ý:\n  - accessToken / staffAccessToken / adminAccessToken tự động lưu sau login thành công\n  - verifyEmailToken / resetPasswordToken / staffSetupToken phải SET THỦ CÔNG từ email"
  },
  "item": [

    {
      "name": "1. Check Account Type",
      "item": [
        {
          "name": "CAT-01 Email student → student",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/check-account-type",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{studentEmail}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('accountType = student', () => pm.expect(b.data.accountType).to.eql('student'));",
            "pm.test('status field = 200', () => pm.expect(b.status).to.eql(200));"
          ]}}]
        },
        {
          "name": "CAT-02 Email staff → staff",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/check-account-type",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{staffEmail}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('accountType = staff', () => pm.expect(b.data.accountType).to.eql('staff'));"
          ]}}]
        },
        {
          "name": "CAT-03 Email không tồn tại → unknown",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/check-account-type",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"nobody_xyz_12345@notexist.com\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('accountType = unknown', () => pm.expect(b.data.accountType).to.eql('unknown'));"
          ]}}]
        },
        {
          "name": "CAT-04 Thiếu email → 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/check-account-type",
            "body": { "mode": "raw", "raw": "{}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));",
            "pm.test('status field = 400', () => pm.expect(pm.response.json().status).to.eql(400));"
          ]}}]
        },
        {
          "name": "CAT-05 Email sai format → 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/check-account-type",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"not-an-email\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));"
          ]}}]
        },
        {
          "name": "CAT-06 Email rỗng → 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/check-account-type",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));"
          ]}}]
        }
      ]
    },

    {
      "name": "2. Login",
      "item": [
        {
          "name": "LGN-01 Student login thành công (lưu accessToken)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{studentEmail}}\",\n  \"password\": \"{{studentPassword}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('role = STUDENT', () => pm.expect(b.data.role).to.eql('STUDENT'));",
            "pm.test('accessToken tồn tại', () => pm.expect(b.data.accessToken).to.be.a('string').and.not.empty);",
            "pm.test('refreshToken tồn tại', () => pm.expect(b.data.refreshToken).to.be.a('string').and.not.empty);",
            "pm.test('KHÔNG có passwordHash trong response', () => pm.expect(JSON.stringify(b)).to.not.include('passwordHash'));",
            "pm.environment.set('accessToken', b.data.accessToken);",
            "pm.environment.set('refreshToken', b.data.refreshToken);"
          ]}}]
        },
        {
          "name": "LGN-02 Staff login thành công (lưu staffAccessToken)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{staffEmail}}\",\n  \"password\": \"{{staffPassword}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('role = STAFF', () => pm.expect(b.data.role).to.eql('STAFF'));",
            "pm.test('staffRole tồn tại', () => pm.expect(b.data.staffRole).to.be.a('string').and.not.empty);",
            "pm.test('requirePasswordChange = false', () => pm.expect(b.data.requirePasswordChange).to.not.eql(true));",
            "pm.environment.set('staffAccessToken', b.data.accessToken);",
            "pm.environment.set('staffRefreshToken', b.data.refreshToken);"
          ]}}]
        },
        {
          "name": "LGN-03 Admin login thành công (lưu adminAccessToken)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('role = ADMIN', () => pm.expect(b.data.role).to.eql('ADMIN'));",
            "pm.test('accessToken tồn tại', () => pm.expect(b.data.accessToken).to.be.a('string').and.not.empty);",
            "pm.test('KHÔNG có passwordHash', () => pm.expect(JSON.stringify(b)).to.not.include('passwordHash'));",
            "pm.environment.set('adminAccessToken', b.data.accessToken);",
            "pm.environment.set('adminRefreshToken', b.data.refreshToken);"
          ]}}]
        },
        {
          "name": "LGN-04 Sai mật khẩu → 401",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{studentEmail}}\",\n  \"password\": \"WrongPass@999\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));",
            "const b = pm.response.json();",
            "pm.test('status field = 401', () => pm.expect(b.status).to.eql(401));",
            "pm.test('data = null (không leak token)', () => pm.expect(b.data).to.be.null);"
          ]}}]
        },
        {
          "name": "LGN-05 Email không tồn tại → 401",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"nobody@notexist.com\",\n  \"password\": \"Any@123456\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));",
            "pm.test('status field = 401', () => pm.expect(pm.response.json().status).to.eql(401));"
          ]}}]
        },
        {
          "name": "LGN-06 Thiếu password → 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{studentEmail}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));"
          ]}}]
        },
        {
          "name": "LGN-07 Thiếu email → 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"password\": \"Student@123\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));"
          ]}}]
        },
        {
          "name": "LGN-08 Body rỗng → 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));"
          ]}}]
        }
      ]
    },

    {
      "name": "3. Register",
      "item": [
        {
          "name": "REG-01 Đăng ký hợp lệ → 201",
          "event": [
            { "listen": "prerequest", "script": { "exec": [
              "pm.environment.set('newEmail', `testuser_${Date.now()}@register.com`);"
            ]}},
            { "listen": "test", "script": { "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "const b = pm.response.json();",
              "pm.test('studentId tồn tại', () => pm.expect(b.data.studentId).to.be.a('number'));",
              "pm.test('email khớp', () => pm.expect(b.data.email).to.eql(pm.environment.get('newEmail')));",
              "pm.test('KHÔNG có passwordHash', () => pm.expect(JSON.stringify(b)).to.not.include('passwordHash'));"
            ]}}
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"Test User\",\n  \"email\": \"{{newEmail}}\",\n  \"password\": \"Test@12345\",\n  \"confirmPassword\": \"Test@12345\"\n}" }
          }
        },
        {
          "name": "REG-02 Email đã tồn tại → 409",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"Dup User\",\n  \"email\": \"{{studentEmail}}\",\n  \"password\": \"Test@12345\",\n  \"confirmPassword\": \"Test@12345\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 409', () => pm.response.to.have.status(409));",
            "pm.test('status field = 409', () => pm.expect(pm.response.json().status).to.eql(409));"
          ]}}]
        },
        {
          "name": "REG-03 Password không có chữ HOA → 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"Test User\",\n  \"email\": \"new@test.com\",\n  \"password\": \"abc12345\",\n  \"confirmPassword\": \"abc12345\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Password thiếu chữ HOA → 400', () => pm.response.to.have.status(400));"
          ]}}]
        },
        {
          "name": "REG-04 Password < 8 ký tự → 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"Test User\",\n  \"email\": \"new@test.com\",\n  \"password\": \"Ab1\",\n  \"confirmPassword\": \"Ab1\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Password quá ngắn → 400', () => pm.response.to.have.status(400));"
          ]}}]
        },
        {
          "name": "REG-05 confirmPassword không khớp → 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"Test User\",\n  \"email\": \"new@test.com\",\n  \"password\": \"Test@12345\",\n  \"confirmPassword\": \"Different@99\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Passwords không khớp → 400', () => pm.response.to.have.status(400));"
          ]}}]
        },
        {
          "name": "REG-06 fullName quá ngắn (1 ký tự) → 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"A\",\n  \"email\": \"new@test.com\",\n  \"password\": \"Test@12345\",\n  \"confirmPassword\": \"Test@12345\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('fullName quá ngắn → 400', () => pm.response.to.have.status(400));"
          ]}}]
        }
      ]
    },

    {
      "name": "4. Email Verification",
      "description": "⚠️ EV-01 và EV-04 cần set 'verifyEmailToken' thủ công từ email xác thực trước khi chạy.",
      "item": [
        {
          "name": "EV-01 Verify email hợp lệ → 200  [cần set verifyEmailToken]",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/verify-email",
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"{{verifyEmailToken}}\"\n}" }
          },
          "event": [
            { "listen": "prerequest", "script": { "exec": [
              "const tok = pm.environment.get('verifyEmailToken');",
              "if (!tok) console.warn('⚠️  verifyEmailToken chưa set — copy từ email xác thực vào environment');"
            ]}},
            { "listen": "test", "script": { "exec": [
              "const tok = pm.environment.get('verifyEmailToken');",
              "if (!tok) { pm.test('SKIP — verifyEmailToken chưa set', () => true); return; }",
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('status field = 200', () => pm.expect(pm.response.json().status).to.eql(200));"
            ]}}
          ]
        },
        {
          "name": "EV-02 Verify email token giả → 400/401",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/verify-email",
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"fake-token-abc123xyz\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Token giả → 4xx', () => pm.expect(pm.response.code).to.be.oneOf([400, 401]));"
          ]}}]
        },
        {
          "name": "EV-03 Verify token rỗng → 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/verify-email",
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Token rỗng → 400', () => pm.response.to.have.status(400));"
          ]}}]
        },
        {
          "name": "EV-04 Resend verification → 200",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/resend-verification",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{newEmail}}\"\n}" }
          },
          "event": [
            { "listen": "prerequest", "script": { "exec": [
              "if (!pm.environment.get('newEmail')) pm.environment.set('newEmail', 'testuser@register.com');"
            ]}},
            { "listen": "test", "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]}}
          ]
        },
        {
          "name": "EV-05 Resend email sai format → 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/resend-verification",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"not-an-email\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Email sai format → 400', () => pm.response.to.have.status(400));"
          ]}}]
        }
      ]
    },

    {
      "name": "5. Refresh Token",
      "item": [
        {
          "name": "RFR-01 Refresh hợp lệ → token mới",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/refresh",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('accessToken mới tồn tại', () => pm.expect(b.data.accessToken).to.be.a('string').and.not.empty);",
            "pm.test('refreshToken mới tồn tại', () => pm.expect(b.data.refreshToken).to.be.a('string').and.not.empty);",
            "pm.test('accessToken mới khác cũ', () => pm.expect(b.data.accessToken).to.not.eql(pm.environment.get('accessToken')));",
            "pm.environment.set('accessToken', b.data.accessToken);",
            "pm.environment.set('refreshToken', b.data.refreshToken);"
          ]}}]
        },
        {
          "name": "RFR-02 refreshToken sai → 401",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/refresh",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"invalid-token-xyz-fake\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Token sai → 401', () => pm.response.to.have.status(401));"
          ]}}]
        },
        {
          "name": "RFR-03 Thiếu refreshToken → 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/refresh",
            "body": { "mode": "raw", "raw": "{}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Thiếu refreshToken → 400', () => pm.response.to.have.status(400));"
          ]}}]
        }
      ]
    },

